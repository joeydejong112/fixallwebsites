# ============================================
# SiteFix — .gitignore
# ============================================

# ============================================
# ENVIRONMENT FILES — never commit these
# ============================================
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# .env.example is intentionally NOT ignored
# It is committed as documentation

# ============================================
# NEXT.JS
# ============================================
.next/
out/
build/
dist/

# Next.js cache
.next/cache/

# Static export
/out

# ============================================
# NODE
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.yarn/

# Package manager locks — commit only one
# If using npm: keep package-lock.json
# If using pnpm: keep pnpm-lock.yaml
# If using yarn: keep yarn.lock
# Delete the others

# ============================================
# CONVEX
# ============================================

# Convex generated files — regenerated by npx convex dev
# Do NOT ignore these — they must be committed
# convex/_generated/ is intentionally not ignored

# Convex local dev state
.convex/

# ============================================
# TYPESCRIPT
# ============================================
*.tsbuildinfo
next-env.d.ts

# ============================================
# SENTRY
# ============================================
.sentryclirc

# Sentry source maps — uploaded during build
# not needed in repo
.sentry/

# ============================================
# VERCEL
# ============================================
.vercel/
.vercel

# ============================================
# OPERATING SYSTEM
# ============================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.AppleDouble
*.LSOverride
Icon

# Windows
desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ============================================
# EDITORS AND IDEs
# ============================================

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
*.swn
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
Session.vim
.netrwhist

# Emacs
*~
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# ============================================
# TESTING
# ============================================
coverage/
.nyc_output/
jest-results/
playwright-report/
playwright/.cache/
test-results/

# ============================================
# LOGS
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# SHARP (IMAGE PROCESSING)
# ============================================

# Sharp downloads platform-specific binaries
# These are large and should not be committed
node_modules/@img/
node_modules/sharp/

# ============================================
# PDF GENERATION
# ============================================

# Temporary PDF files generated during development
*.pdf
!public/**/*.pdf

# ============================================
# UPLOADS AND GENERATED FILES
# ============================================

# Any temporary uploads during development
uploads/
tmp/
temp/
.tmp/

# Generated sitemaps (created by next-sitemap postbuild)
# Commit these if you want them in the repo
# Uncomment to ignore:
# public/sitemap*.xml
# public/robots.txt

# ============================================
# QA REPORTS — your choice whether to commit
# ============================================

# QA reports document the build history.
# Recommended: commit them.
# Uncomment below to ignore instead:
# QA_REPORT_AGENT_*.md

# ============================================
# MISCELLANEOUS
# ============================================

# Turbopack cache
.turbo/

# ESLint cache
.eslintcache

# Prettier cache
.prettiercache

# Stylelint cache
.stylelintcache

# Optional: ignore the Tailwind CSS cache
.tailwindcss/

# Storybook
storybook-static/
.storybook/

# Bundle analyzer output
.analyze/
bundle-analyzer-report.html

# Local SSL certificates (if used for local HTTPS)
*.pem
*.key
*.crt
*.csr
localhost+*.pem

# Backup files
*.bak
*.backup
*.orig

# ============================================
# FILES THAT MUST NEVER BE IGNORED
# ============================================

# These are force-included even if patterns above
# would catch them. The ! prefix un-ignores them.

# Convex generated types — must be committed
!convex/_generated/

# Environment template — must be committed
!.env.example

# All reference and memory files — must be committed
!AGENTS.md
!AGENT_MEMORY.md
!DONE_MEANS_DONE.md
!DESIGN_TOKENS.md
!CONVEX_REGISTRY.md
!SCAN_CHECKS.md
!implementation_plan.md

# Workflow files — must be committed
!.agents/
!.agents/workflows/
!.agents/workflows/build-agent.md
!.agents/workflows/qa-agent.md

# Public assets — must be committed
!public/llms.txt
!public/og-image.png
